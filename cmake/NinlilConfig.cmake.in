@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(@NINLIL_CONFIG_HAS_POSIX_SQLITE@)
    find_dependency(SQLite3)
    if(NOT TARGET SQLite3::SQLite3 AND TARGET SQLite::SQLite3)
        add_library(SQLite3::SQLite3 ALIAS SQLite::SQLite3)
    endif()
    # Static libsqlite3.a private system deps must be re-found by consumers.
    if(@NINLIL_CONFIG_SQLITE_STATIC@)
        if(@NINLIL_CONFIG_SQLITE_NEEDS_THREADS@)
            find_dependency(Threads)
        endif()
        if(@NINLIL_CONFIG_SQLITE_NEEDS_ZLIB@)
            find_dependency(ZLIB)
        endif()
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/NinlilTargets.cmake")
check_required_components(Ninlil)
