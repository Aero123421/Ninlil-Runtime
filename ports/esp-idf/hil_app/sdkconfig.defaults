CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="../partitions/ninlil_storage.csv"
CONFIG_PARTITION_TABLE_FILENAME="../partitions/ninlil_storage.csv"
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_WL_SECTOR_SIZE_4096=y
CONFIG_WL_SECTOR_SIZE=4096
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_CAPS_ALLOC=y

# U2: control CDC enabled for link of A2 adapter symbols; console stays UART.
CONFIG_TINYUSB_CDC_ENABLED=y
CONFIG_TINYUSB_CDC_COUNT=1

# R7 component consumer requirement. This only enables target compile/link;
# it does not turn the storage power-cut app into an R7 device/HIL verdict.
CONFIG_MBEDTLS_HKDF_C=y
